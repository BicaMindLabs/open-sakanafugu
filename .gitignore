# ── secrets — never enter the repo ───────────────────
**/.ccb/ccb.config        # ccb config with the real key (only ccb.config.example is tracked)
*secrets*.env
cc-model-secrets.env
.env
.env.*

# ── runtime / cache ──────────────────────────────────
node_modules/
.claude-envs/*/opt/
.fanout-cache/        # fan-out result cache (runtime, round-N/ per round)
*.log
.DS_Store

# ── ccb runtime ──────────────────────────────────────
.ccb/state/
.ccb/*.sock
.ccb/logs/

# ── task / report artifacts ──────────────────────────
tasks/*.local.md
reports/

# Python bytecode
__pycache__/
*.pyc
