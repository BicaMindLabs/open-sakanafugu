#!/usr/bin/env node
import { runSubcommandBridge } from "./fuguectl-node-bridge.mjs";

runSubcommandBridge({
  argv: process.argv.slice(2),
  command: "runtime",
  allowed: ["check", "adapt"],
  help: `fuguectl-runtime — TypeScript runtime sync bridge

check            print current/last provider version + workflow skill drift
adapt [--apply]  verify grafting, sync workflow skill, optionally restart daemon, preflight, record version

Options: --skill <installed SKILL.md> --repo-skill <repo SKILL.md>
`,
  unknown: (subcommand) =>
    `fuguectl-runtime: unknown subcommand '${subcommand}' (check|adapt)`,
});
