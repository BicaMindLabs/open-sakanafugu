# Unify line endings, prevent cross-platform CRLF from polluting scripts
* text=auto eol=lf

*.sh        text eol=lf
*-code      text eol=lf
*.mjs       text eol=lf
*.tsv       text eol=lf
Makefile    text eol=lf

# Language stats: count launchers as Shell
*-code linguist-language=Shell
backends/bin/cc-models linguist-language=Shell
backends/bin/cc-sync   linguist-language=Shell

# Docs excluded from language stats
docs/**     linguist-documentation
*.md        linguist-documentation
