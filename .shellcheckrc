# shellcheck config — shared by local / CI / pre-commit
#
# SC2034 (unused variable): each <provider>-code launcher head defines MODELS / CC_OPUS /
#   CC_SONNET / CC_HAIKU / CC_FAST / CC_SUBAGENT / CC_MODEL_* etc., consumed by the
#   cc_model_launch() sourced in at runtime (in cc-model-lib.sh). shellcheck can't do
#   cross-source data-flow analysis, so it reports them all as "unused" — all false
#   positives.
disable=SC2034
#
# SC1090/SC1091 (can't follow source): the launchers source cc-model-lib.sh via a dynamic
#   path; static analysis can't follow it, not a defect.
disable=SC1090,SC1091
