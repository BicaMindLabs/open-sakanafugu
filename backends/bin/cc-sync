#!/usr/bin/env node
import {
  existsSync,
  mkdirSync,
  readFileSync,
  readdirSync,
  writeFileSync,
  copyFileSync,
} from "node:fs";
import { basename, join } from "node:path";
import { spawnSync } from "node:child_process";

process.env.PATH = `/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin:${process.env.HOME ?? ""}/.npm-global/bin:${process.env.PATH ?? ""}`;

const envs = [
  "deepseek",
  "glm",
  "kimi",
  "qwen",
  "doubao",
  "minimax",
  "mimo",
  "stepfun",
  "longcat",
  "local",
];
const bin = join(process.env.HOME ?? "", "bin");
const noProbe = "qwen doubao kimi mimo longcat";
const probes = [
  ["glm", "https://api.z.ai/api/anthropic/v1/models", "GLM_API_KEY", /^glm-/u],
  [
    "minimax",
    "https://api.minimaxi.com/anthropic/v1/models",
    "MINIMAX_API_KEY",
    /^MiniMax-/u,
  ],
  [
    "stepfun",
    "https://api.stepfun.com/step_plan/v1/models",
    "STEPFUN_API_KEY",
    /^step-(3|router)/u,
  ],
  [
    "deepseek",
    "https://api.deepseek.com/v1/models",
    "DEEPSEEK_API_KEY",
    /^deepseek-/u,
  ],
];

const run = (cmd, args, options = {}) =>
  spawnSync(cmd, args, {
    encoding: "utf8",
    ...options,
  });

const getKey = (name) => {
  const result = run("zsh", ["-lic", `printf %s "$${name}"`], {
    stdio: ["ignore", "pipe", "ignore"],
  });
  return result.status === 0 ? result.stdout : "";
};

const syncCli = () => {
  const latestResult = run(
    "npm",
    ["view", "@anthropic-ai/claude-code", "version"],
    {
      stdio: ["ignore", "pipe", "ignore"],
    },
  );
  const latest = latestResult.stdout.trim();
  if (latest.length === 0) {
    console.log("[cli] ❌ unable to get the latest npm version");
    return 1;
  }

  let changed = false;
  console.log(`[cli] target latest version: ${latest}`);
  const currentResult = run("npm", ["ls", "-g", "@anthropic-ai/claude-code"], {
    stdio: ["ignore", "pipe", "ignore"],
  });
  const current =
    /[0-9]+\.[0-9]+\.[0-9]+[-a-z0-9.]*/iu.exec(currentResult.stdout)?.[0] ?? "";
  if (current !== latest) {
    const result = run(
      "npm",
      [
        "i",
        "-g",
        `@anthropic-ai/claude-code@${latest}`,
        "--no-fund",
        "--no-audit",
      ],
      {
        stdio: "ignore",
      },
    );
    if (result.status === 0) {
      console.log(`[cli] main: ${current} -> ${latest}`);
      changed = true;
    } else {
      console.log("[cli] main: upgrade failed");
    }
  } else {
    console.log(`[cli] main: ${latest} (already latest)`);
  }

  for (const name of envs) {
    const opt = join(process.env.HOME ?? "", ".claude-envs", name, "opt");
    if (!existsSync(opt)) continue;
    const packageFile = join(
      opt,
      "node_modules",
      "@anthropic-ai",
      "claude-code",
      "package.json",
    );
    let version = "";
    try {
      version = JSON.parse(readFileSync(packageFile, "utf8")).version ?? "";
    } catch {
      version = "";
    }
    if (version !== latest) {
      const result = run(
        "npm",
        ["i", `@anthropic-ai/claude-code@${latest}`, "--no-fund", "--no-audit"],
        {
          cwd: opt,
          stdio: "ignore",
        },
      );
      if (result.status === 0) {
        console.log(`[cli] ${name}: ${version || "none"} -> ${latest}`);
        changed = true;
      } else {
        console.log(`[cli] ${name}: upgrade failed`);
      }
    } else {
      console.log(`[cli] ${name}: ${latest}`);
    }
  }

  console.log(
    changed ? "[cli] ✅ updates applied" : "[cli] ✅ everything already latest",
  );
  return 0;
};

const launcherModels = (provider) => {
  const result = run(join(bin, `${provider}-code`), ["--list"], {
    stdio: ["ignore", "pipe", "ignore"],
  });
  if (result.status !== 0) return [];
  return result.stdout.split(/\r?\n/u).filter((item) => item.length > 0);
};

const appendLauncherModels = (provider, models) => {
  const runtime = join(bin, "cc-model-launcher.mjs");
  const text = readFileSync(runtime, "utf8");
  const pattern = new RegExp(
    `(const models = \\[)([^\\]]*)(\\];\\n\\s*const profile = get\\("${provider.toUpperCase()}_PROFILE)`,
    "u",
  );
  const match = pattern.exec(text);
  if (match === null) return false;
  const current = [...match[2].matchAll(/"([^"]+)"/gu)].map((item) => item[1]);
  const next = [
    ...current,
    ...models.filter((model) => !current.includes(model)),
  ];
  const replacement = `${match[1]}${next
    .map((model) => JSON.stringify(model))
    .join(", ")}${match[3]}`;
  writeFileSync(runtime, text.replace(pattern, replacement));
  return true;
};

const endpointModels = (body, filter) => {
  try {
    const data = JSON.parse(body);
    const arr = Array.isArray(data.data)
      ? data.data
      : Array.isArray(data.models)
        ? data.models
        : [];
    return arr
      .map((item) =>
        typeof item === "object" && item !== null ? (item.id ?? item.name) : "",
      )
      .filter((item) => typeof item === "string" && filter.test(item))
      .sort();
  } catch {
    return [];
  }
};

const syncModels = (apply) => {
  for (const [provider, url, keyEnv, filter] of probes) {
    const key = getKey(keyEnv);
    if (key.length === 0) {
      console.log(`[models] ${provider}: no key, skip`);
      continue;
    }

    const result = run(
      "curl",
      [
        "-sS",
        "-m",
        "20",
        url,
        "-H",
        `x-api-key: ${key}`,
        "-H",
        `authorization: Bearer ${key}`,
        "-H",
        "anthropic-version: 2023-06-01",
      ],
      { stdio: ["ignore", "pipe", "ignore"] },
    );
    const remote = [...new Set(endpointModels(result.stdout, filter))].sort();
    if (remote.length === 0) {
      console.log(`[models] ${provider}: /v1/models returned nothing, skip`);
      continue;
    }

    const have = new Set(launcherModels(provider));
    const foundNew = remote.filter((model) => !have.has(model));
    if (foundNew.length === 0) {
      console.log(
        `[models] ${provider}: ✅ no new models (${remote.length} endpoint models already covered)`,
      );
      continue;
    }

    console.log(
      `[models] ${provider}: 🆕 new at endpoint -> ${foundNew.join(" ")}`,
    );
    if (!apply) continue;

    const add = foundNew.filter((model) => !have.has(model));
    if (add.length === 0) continue;
    if (appendLauncherModels(provider, add)) {
      console.log(
        `[models] ${provider}: ✅ appended ${add.length} into launcher runtime (default profile untouched, manually promote flagship when needed)`,
      );
    } else {
      console.log(
        `[models] ${provider}: ⚠️  could not auto-edit launcher runtime; add manually`,
      );
    }
  }
  console.log(
    `[models] needs human check (no clean endpoint list): ${noProbe}`,
  );
};

const stamp = () =>
  new Date()
    .toISOString()
    .replace(/[-:]/gu, "")
    .replace(/\..*$/u, "")
    .replace("T", "-");

const research = () => {
  const prompt = join(bin, "cc-model-research-prompt.md");
  if (!existsSync(prompt)) {
    console.log(`[research] ❌ missing ${prompt}`);
    return 1;
  }
  if (run("claude", ["--version"], { stdio: "ignore" }).status !== 0) {
    console.log("[research] ❌ claude not found");
    return 1;
  }

  const backup = join(bin, `.cc-launchers-bak.${stamp()}`);
  mkdirSync(backup, { recursive: true });
  for (const file of readdirSync(bin)) {
    if (file.endsWith("-code") || file === "cc-model-registry.tsv") {
      copyFileSync(join(bin, file), join(backup, file));
    }
  }
  console.log(`[research] backup -> ${backup}`);
  console.log(
    "[research] launching headless research agent (read each vendor's official docs->learn->rebuild launchers->live verify)...",
  );

  const env = { ...process.env };
  for (const key of [
    "CLAUDE_CODE_SESSION_ID",
    "CLAUDE_CODE_CHILD_SESSION",
    "CLAUDE_CODE_SDK_HAS_OAUTH_REFRESH",
    "CLAUDE_CODE_SDK_HAS_HOST_AUTH_REFRESH",
    "CLAUDE_CODE_OAUTH_SCOPES",
  ]) {
    delete env[key];
  }
  spawnSync(
    "claude",
    ["-p", readFileSync(prompt, "utf8"), "--dangerously-skip-permissions"],
    {
      cwd: bin,
      env,
      stdio: "inherit",
    },
  );

  let broke = false;
  for (const provider of [
    "deepseek",
    "glm",
    "kimi",
    "qwen",
    "doubao",
    "minimax",
    "mimo",
    "stepfun",
    "longcat",
  ]) {
    const file = join(bin, `${provider}-code`);
    if (!existsSync(file)) continue;
    const result = run("bash", ["-n", file], { stdio: "ignore" });
    if (result.status === 0) continue;
    console.log(
      `[research] ⚠️ ${basename(file)} syntax broken -> restoring from backup`,
    );
    copyFileSync(join(backup, basename(file)), file);
    broke = true;
  }
  run(process.execPath, ["--check", join(bin, "cc-sync")], { stdio: "ignore" });
  console.log(
    broke
      ? `[research] ⚠️ some launchers were restored (see above), backup in ${backup}`
      : "[research] ✅ all launchers syntax OK after changes",
  );
  return 0;
};

const applyFlag = process.argv[3] === "--apply";

switch (process.argv[2] ?? "all") {
  case "cli":
    process.exit(syncCli());
  case "models":
    syncModels(applyFlag);
    break;
  case "research":
    process.exit(research());
  case "all":
  case "":
    syncCli();
    console.log();
    syncModels(applyFlag);
    break;
  default:
    console.error(
      "Usage: cc-sync {cli|models [--apply]|research|all [--apply]}",
    );
    process.exit(1);
}
